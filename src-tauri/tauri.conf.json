{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Spec Plan Manager",
  "version": "0.2.3",
  "identifier": "com.specplan.manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Spec Plan Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyNjJBMjY4NEQyQkJBNTIKUldSU3VpdE5hS0ppY3Ricjl5b1ltdmxDYlg3UzBHdE11dmVQb2FjaEM3VURDSnE3MDEzditDUGwK",
      "endpoints": [
        "https://github.com/weihung0831/spec-ui/releases/latest/download/latest.json"
      ]
    }
  }
}
